{
  "name": "lumabin-desktop",
  "productName": "LumaBin",
  "version": "1.0.3",
  "description": "LumaBin desktop app (Electron + React + Vite + TypeScript)",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "dev": "electron-forge start",
    "dev:e2e": "LUMABIN_E2E=1 LUMABIN_E2E_FIXTURE=1 LUMABIN_E2E_RUN_ID=${LUMABIN_E2E_RUN_ID:-default} electron-forge start -- --remote-debugging-port=${LUMABIN_E2E_CDP_PORT:-9222}",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "package:darwin": "electron-forge make --platform=darwin --arch=arm64 && node ./scripts/fix-darwin-artifact.mjs",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "typecheck": "tsc --noEmit",
    "smoke:integration": "tsc -p tsconfig.integration.json && node .tmp/integration/main/__integration__/storage-client.smoke.js",
    "smoke:ui": "vitest run --config vitest.ui.config.ts",
    "e2e": "npm run package:darwin && node ./scripts/release-launch-smoke.mjs --app",
    "e2e:dense": "npm run package:darwin && LUMABIN_E2E_DENSE=1 LUMABIN_E2E_FIXTURE_ASSET_COUNT=1000 LUMABIN_E2E_TEST_GREP=\"dense fixture\" node ./scripts/release-launch-smoke.mjs --app",
    "e2e:attach": "LUMABIN_E2E_ATTACH=1 playwright test --config playwright.e2e.config.ts",
    "e2e:prelaunch": "npm run package:darwin && open out/LumaBin-darwin-arm64/LumaBin.app --args --use-mock-keychain --remote-debugging-port=${LUMABIN_E2E_CDP_PORT:-9222} --lumabin-e2e --lumabin-e2e-fixture --lumabin-e2e-run-id=${LUMABIN_E2E_RUN_ID:-manual}",
    "e2e:headed": "npm run package:darwin && node ./scripts/release-launch-smoke.mjs --app --headed",
    "e2e:install": "playwright install chromium",
    "smoke:ci": "npm run lint && npm run typecheck && npm run smoke:integration && npm run smoke:ui && npm run audit:runtime && npm run audit:public-readiness",
    "verify:darwin-artifact": "node ./scripts/verify-darwin-artifact.mjs",
    "verify:mac-signing-readiness": "node ./scripts/verify-mac-signing-readiness.mjs",
    "release:launch-smoke": "node ./scripts/release-launch-smoke.mjs",
    "verify:dev-metrics-snapshot": "node ./scripts/verify-dev-metrics-snapshot.mjs",
    "release:preflight": "node ./scripts/release-preflight.mjs",
    "release:preflight:verify-only": "node ./scripts/release-preflight.mjs --verify-only",
    "release:public-snapshot": "node ./scripts/create-public-snapshot.mjs",
    "verify:public-snapshot-import": "node ./scripts/verify-public-snapshot-import.mjs",
    "perf:real-profile:attach": "node ./scripts/real-profile-dev-metrics.mjs",
    "audit:public-history": "node ./scripts/audit-public-readiness.mjs --history",
    "audit:github-public-readiness": "node ./scripts/audit-github-public-readiness.mjs --post-public",
    "audit:github-prepublic-readiness": "node ./scripts/audit-github-public-readiness.mjs --pre-public",
    "audit:public-readiness": "node ./scripts/audit-public-readiness.mjs",
    "audit:all": "npm audit --cache /tmp/lumabin-npm-cache",
    "audit:runtime": "npm audit --omit=dev --audit-level=high",
    "audit:runtime:local": "npm audit --omit=dev --audit-level=high --cache /tmp/lumabin-npm-cache"
  },
  "keywords": [],
  "author": {
    "name": "satoooh"
  },
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "electron-squirrel-startup": "^1.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "^0.34.4"
  },
  "overrides": {
    "fast-xml-parser": "^5.4.1",
    "@electron/rebuild": "^4.0.3",
    "tar": "^7.5.8",
    "serialize-javascript": "^7.0.5",
    "tmp": "^0.2.5"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "41.5.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.0.18"
  }
}
